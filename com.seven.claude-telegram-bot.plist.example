<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.seven.claude-telegram-bot</string>

  <key>ProgramArguments</key>
  <array>
    <!-- Use pyenv python path if needed:
         /Users/yourname/.pyenv/shims/python3 -->
    <string>/usr/bin/python3</string>
    <string>/Users/yourname/.claude/telegram-bot/bot.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/yourname/.claude/telegram-bot</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/claude-telegram-bot.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/claude-telegram-bot.err</string>

  <key>ThrottleInterval</key>
  <integer>10</integer>
</dict>
</plist>
