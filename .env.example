# Telegram Bot Configuration
# Copy this file to .env and fill in your values

# Required: your Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Required: your personal Telegram chat ID (get it from @userinfobot)
ALLOWED_CHAT_ID=123456789

# Optional: comma-separated group chat IDs where the bot should respond
# ALLOWED_GROUP_IDS=-1001234567890,-1009876543210

# Optional: how many conversation rounds to keep in context (default: 3)
# CONTEXT_LENGTH=3

# Note: API keys and endpoints are managed by Claude Code itself (claude config set).
# This bot only invokes the `claude` CLI — no API credentials needed here.
