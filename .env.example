# Telegram Bot — Secrets only (dynamic config lives in config.json)

# Required: your Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Claude API credentials (passed to claude CLI subprocess)
# For direct Anthropic access:
# ANTHROPIC_API_KEY=sk-ant-...
# For OpenRouter or other proxy:
# ANTHROPIC_AUTH_TOKEN=sk-or-...
# ANTHROPIC_BASE_URL=https://openrouter.ai/api

# Admin panel authentication token (leave empty to disable auth)
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=
